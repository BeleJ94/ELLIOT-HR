APP_NAME=ELLIOT-HR
APP_ENV=local
APP_DEBUG=false
# Utiliser "auto" en VPS si le domaine peut changer ou si l'application est derriere un proxy.
# Exemple domaine fixe: APP_URL=https://rh.votre-domaine.com
APP_URL=auto
APP_TIMEZONE=Africa/Lubumbashi
APP_LOCALE=fr

DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# Remplacer ces trois valeurs dans le fichier .env de chaque environnement.
# Ne jamais placer les identifiants du VPS dans ce fichier versionne.
DB_DATABASE=nom_de_la_base
DB_USERNAME=utilisateur_de_la_base
DB_PASSWORD=mot_de_passe_de_la_base
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
